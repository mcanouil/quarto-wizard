{
	"GitHub config": {
		"prefix": "github-meta",
		"body": [
			"filters:",
			"  - path: gitlink",
			"    at: post-quarto",
			"extensions:",
			"  gitlink:",
			"    platform: github",
			"    repository-name: ${1:owner/repo}"
		],
		"description": "Activate gitlink for GitHub references"
	},
	"Navbar widget config": {
		"prefix": "gitlink-widget-meta",
		"body": [
			"filters:",
			"  - path: gitlink",
			"    at: post-quarto",
			"extensions:",
			"  gitlink:",
			"    platform: ${1:github}",
			"    repository-name: ${2:owner/repo}",
			"    widget:",
			"      enabled: true"
		],
		"description": "Activate the gitlink repository navbar widget"
	},
	"GitLab config": {
		"prefix": "gitlab-meta",
		"body": [
			"filters:",
			"  - path: gitlink",
			"    at: post-quarto",
			"extensions:",
			"  gitlink:",
			"    platform: gitlab",
			"    base-url: https://gitlab.com",
			"    repository-name: ${1:group/project}"
		],
		"description": "Activate gitlink for GitLab references"
	}
}
